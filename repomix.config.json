{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "topFilesLength": 20
  },
  "include": ["**/*"],
  "ignore": {
    "useGitignore": false,
    "useDotIgnore": true,
    "useDefaultPatterns": true
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
