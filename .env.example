# Sancho Fetch -- workspace settings + API key template
#
# Copy this file to `.env` in your workspace root and fill in the keys
# for the providers you plan to use. All keys are free.
# See README.md "API Keys" section for signup links.
#
# `.env` is personal and never overwritten by `sancho update`.
#
# =====================================================================
# COMMUNICATION STYLE FOR AI ASSISTANTS  (read this FIRST)
# =====================================================================
# SANCHO_DEVELOPER_MODE controls how the AI assistant talks to you in
# this workspace. Agents should check it through `sancho mode --json`
# instead of opening this file directly. It is a soft instruction, not a
# code feature flag.
#
#   SANCHO_DEVELOPER_MODE=false   <- DEFAULT
#     Talk in plain language. No code commands, no jargon. If a step
#     requires running something (install, init, fetch), the AI asks
#     "Want me to do this for you?" and runs it ITSELF -- it does not
#     paste terminal commands at the user. Technical terms (API key,
#     workspace, .env) are defined when first used.
#
#     Example reply when the user says "hi":
#       "Hi! Want me to set this up for you? It just means I'll create
#        a working folder where your data and notes will live. Some
#        data sources need a free API key (a personal password the
#        website gives you so it knows the requests are coming from
#        you) -- I can tell you which ones based on what you want to
#        look at. To add keys, open the file `.env` (you can use any
#        text editor, or download VS Code if you don't have one) and
#        paste the keys in next to the matching name."
#
#   SANCHO_DEVELOPER_MODE=true
#     You are a developer. The AI can show terminal commands, file
#     paths, code, diffs, env-var names, and technical detail freely.
#
# Toggle by changing the line below. Set once and forget.

SANCHO_DEVELOPER_MODE=false


# =====================================================================
# WHAT YOU NEED TO FILL THIS OUT (auto-fill friendly summary)
# =====================================================================
# Every provider below asks for some subset of the same small set of
# fields. If an automation (e.g. a Chrome DevTools MCP agent) is going
# to sign up on your behalf, have these ready:
#
#   * First name
#   * Last name  (or a single "Display Name" for Socrata)
#   * Email address (you must be able to click confirmation links)
#   * Organization name (BLS, BEA, Census -- can be your own name)
#   * Password (only for FRED and Socrata -- everywhere else is
#     email-only issuance)
#   * Optional "How will you use this?" free text (api.data.gov,
#     Congress.gov, EIA) -- one generic sentence reused everywhere is fine
#   * Ability to solve a CAPTCHA (BLS, BEA, HUD, Socrata) -- HUD also
#     gates the whole page behind a bot-check.
#   * A category dropdown selection for EIA (e.g. "Private citizen")
#
# Every provider requires agreeing to a Terms of Service checkbox.
# No provider asks for a phone, address, or payment.
#
# All APIs below are pinned to their current latest stable versions
# (FRED n/a, BEA n/a, Census ACS 5-year, Congress v3, NOAA CDO v2,
#  EIA v2, BLS v2, Socrata SODA v2.1). The underlying fetch modules
# were audited 2026-04-09.
# =====================================================================


# =============================================================================
#  US FEDERAL -- KEY REQUIRED
# =============================================================================

# --- api.data.gov umbrella key -----------------------------------------
# Unlocks: fetch.fbi.crime, fetch.fec, fetch.regulations.dockets,
#          fetch.nrel.alt_fuel_stations, fetch.college_scorecard.schools,
#          fetch.nhtsa.recalls
# Signup: https://api.data.gov/signup/
# Fields required:
#   - First Name *
#   - Last Name *
#   - Email *
#   - "How will you use the APIs?" (optional free text)
#   - No CAPTCHA, no password. Key is shown immediately on-screen AND
#     emailed.
DATA_GOV_API_KEY=

# --- Federal Reserve Economic Data (FRED) ------------------------------
# API: https://api.stlouisfed.org/fred/  (unversioned, always current)
# Signup: https://fredaccount.stlouisfed.org/login/register
# Fields required (full account, not just a key form):
#   - Email Address *
#   - Password * + Confirm Password *
#   - "In what context do you use FRED?" dropdown *
#     (Business Professional | Economics Enthusiast | Journalist |
#      Researcher/Academic | Student | Teacher)
#   - Optional newsletter checkboxes (leave unchecked)
#   - Email confirmation link, then request API key at
#     https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# --- Bureau of Labor Statistics (BLS) ----------------------------------
# API: https://api.bls.gov/publicAPI/v2/  (v2 -- current)
# Signup: https://data.bls.gov/registrationEngine/
# Fields required:
#   - Organization Name
#   - Email Address
#   - CAPTCHA (numeric, image-based -- has audio fallback)
#   - Terms of Service checkbox
#   - Key is emailed.
BLS_API_KEY=

# --- Bureau of Economic Analysis (BEA) ---------------------------------
# API: https://apps.bea.gov/api/data  (unversioned, always current)
# Signup: https://apps.bea.gov/API/signup/
# Fields required:
#   - Name (your name or organization)
#   - Email
#   - CAPTCHA (text)
#   - Terms of Service checkbox
#   - Key is emailed.
# NOTE: After signup, BEA will email you an activation link. You MUST
# click the link to activate the key before it will work. Until
# activated, requests return "UserId is not authorized to access".
BEA_API_KEY=

# --- US Census Bureau --------------------------------------------------
# API: https://api.census.gov/data/{year}/acs/acs5/profile  (ACS 5-year)
# Signup: https://api.census.gov/data/key_signup.html
# Fields required:
#   - Organization Name *
#   - Email Address *
#   - Terms of Service checkbox
#   - No CAPTCHA. Key is emailed.
# NOTE: After signup, Census will email you an activation link. You MUST
# click the link to activate the key. An unactivated key returns an HTML
# "Invalid Key" page instead of JSON.
CENSUS_API_KEY=

# --- Congress.gov ------------------------------------------------------
# API: https://api.congress.gov/v3/  (v3 -- current)
# Signup: https://api.congress.gov/sign-up/
# Fields required:
#   - First Name *
#   - Last Name *
#   - Email *
#   - "How will you use the APIs?" (optional free text)
#   - No CAPTCHA, no password. Key is emailed.
CONGRESS_API_KEY=

# --- HUD USER (Fair Market Rents, etc.) --------------------------------
# API: https://www.huduser.gov/hudapi/public/  (current)
# Signup: https://www.huduser.gov/hudapi/public/register
# Fields required:
#   - **Bot-check gate first** ("Let's confirm you are human" challenge)
#   - Then a full HUD USER account: first name, last name, email,
#     password, organization. Email confirmation required.
#   - After login, generate an API token from the account dashboard.
#   - This is the slowest signup of the bunch -- the only one that isn't
#     fully instant.
HUD_API_TOKEN=

# --- NOAA Climate Data Online (CDO) ------------------------------------
# API: https://www.ncei.noaa.gov/cdo-web/api/v2/  (v2 -- current)
# Signup: https://www.ncdc.noaa.gov/cdo-web/token
# Fields required:
#   - Email address (that's it)
#   - No name, no password, no CAPTCHA, no ToS checkbox.
#   - Token is emailed instantly.
NOAA_API_TOKEN=

# --- US Energy Information Administration (EIA) ------------------------
# API: https://api.eia.gov/v2/  (v2 -- current; v1 was deprecated)
# Signup: https://www.eia.gov/opendata/register.php
# Fields required:
#   - First Name *
#   - Last Name *
#   - Email *
#   - Category dropdown * (e.g. "Private citizen", "Research/Consulting",
#     "Student", "Business/Industry" -- any value works)
#   - "Reason to use this API" (optional free text)
#   - Terms of Service checkbox *
#   - Key is emailed.
EIA_API_KEY=

# --- USDA Quick Stats (NASS) -------------------------------------------
# API: https://quickstats.nass.usda.gov/api/  (unversioned, current)
# Signup: https://quickstats.nass.usda.gov/api (scroll to "Request API Key")
# Fields required:
#   - Email address
#   - Agree to NASS Terms of Service
#   - Key is emailed.
USDA_NASS_API_KEY=


# --- SEC EDGAR (contact email for User-Agent header) -----------------
# SEC requires a contact email in the User-Agent header for EDGAR API.
# Not a key -- just your email so SEC can contact you if needed.
# No signup required.
SEC_CONTACT_EMAIL=

# --- EPA Air Quality System (AQS) ------------------------------------
# Signup: https://aqs.epa.gov/aqsweb/documents/data_api.html
# Requires both an API key and the email you signed up with.
# (Email the one-time request to aqsdatamart@epa.gov or use the
# self-serve signup form; key is emailed instantly.)
AQS_API_KEY=
AQS_EMAIL=

# --- AirNow API (EPA real-time AQI + forecasts) ----------------------
# API: https://docs.airnowapi.org/  (current; web-services format)
# Signup: https://docs.airnowapi.org/account/request/
# Fields required:
#   - Email
#   - First/Last Name
#   - Organization (optional)
#   - Intended use (short free text)
#   - Terms of Service checkbox
# NOTE: AirNow emails you an activation link after signup. You must
# click the link to activate the account. The API key is shown on
# your AirNow account dashboard once activated.
AIRNOW_API_KEY=

# --- DOL OSHA Inspections --------------------------------------------
# Signup: https://developer.dol.gov/beginners-guide/
# Fields: Email, organization. Key emailed.
DOL_API_KEY=

# --- USPTO Open Data Portal (ODP) -------------------------------------
# API: https://api.uspto.gov/ (Open Data Portal -- patents, trademarks)
# Docs: https://data.uspto.gov/apis/getting-started
# Swagger: https://data.uspto.gov/apis/swagger
# Signup flow (multi-step, ~5-10 min):
#   1. Create a USPTO.gov account at https://my.uspto.gov/
#      - Fields: name, email, password, terms of use
#      - Activate via email (link expires in 48h)
#   2. From MyODP (https://data.uspto.gov/myodp/), click
#      "Verify USPTO.gov account with ID.me" and create an ID.me
#      account. Identity verification is required (self-serve or
#      video call; international users must use the video call).
#   3. Back on MyODP, link ID.me to your USPTO.gov account. Your
#      API key is then displayed on the MyODP page.
# Auth: Send as HTTP header "x-api-key: <your key>"
# Note: Key expires only if unused for 12+ months.
USPTO_API_KEY=


# =============================================================================
#  US CIVIC / SOCRATA -- OPTIONAL TOKEN
# =============================================================================

# --- Socrata / Tyler Data & Insights (optional -- raises rate limits) ---
# Used by: fetch.nyc_open_data, fetch.cdc, fetch.socrata.chicago_crimes,
#          fetch.socrata.la_crime, fetch.socrata.sf_building_permits,
#          fetch.socrata.seattle_building_permits, fetch.socrata.dataset
# API: SODA v2.1 (https://{domain}/resource/{dataset}.json -- current)
# Signup: https://evergreen.data.socrata.com/signup
#         (Socrata is now "Tyler Data & Insights")
# Fields required:
#   - Email Address
#   - Display Name
#   - Password + Confirm Password
#   - reCAPTCHA
#   - Terms of Service checkbox
#   - After confirming email, go to developer settings to create API keys.
#   - Auth: API Key ID + Secret sent as HTTP Basic Auth.
#   - NOTE: modules work without keys; auth only raises rate limits.
SODA_API_KEY_ID=
SODA_API_KEY_SECRET=


# =============================================================================
#  US FEDERAL -- NO KEY REQUIRED  (listed for reference)
# =============================================================================
# USGS earthquakes (fdsnws/event/1), Federal Register (v1),
# SEC EDGAR (data.sec.gov), ClinicalTrials.gov (v2), openFDA,
# CMS provider-data (v1), Treasury Fiscal Data (v1),
# USAspending (v2), FEMA OpenFEMA (v1), EPA ECHO,
# CFPB (v1), FDIC BankFind,
# DOJ press releases (v1), GSA CALC (v3),
# NAEP, Open Payments CMS (v1), USDA FoodData (v1).


# =============================================================================
#  GEOSPATIAL / REMOTE SENSING -- OPTIONAL KEYS
# =============================================================================

# --- Google Earth Engine -------------------------------------------------
# Requires: earthengine-api package + `earthengine authenticate` CLI
# Project ID is optional (only needed if your GEE account requires one)
# Setup: https://developers.google.com/earth-engine/guides/getstarted
EARTHENGINE_PROJECT=

# --- Microsoft Planetary Computer ----------------------------------------
# Optional subscription key for higher rate limits. Public access works
# without a key for most collections.
# Setup: https://planetarycomputer.microsoft.com/docs/concepts/sas/
PC_SDK_SUBSCRIPTION_KEY=

# --- NASA Earthdata -------------------------------------------------------
# Bearer token for accessing NASA EOSDIS data (GUPPD, etc.)
# Signup: https://urs.earthdata.nasa.gov/users/new
EARTHDATA_TOKEN=


# =============================================================================
#  INTERNATIONAL -- GOVERNANCE & DEMOCRACY  (no keys required)
# =============================================================================
# All governance/democracy modules work without API keys:
#   fetch.vdem -- V-Dem (Varieties of Democracy) core indicators (CSV archive)
#   fetch.wgi -- World Governance Indicators (World Bank API, no key)
#   fetch.wjp_rule_of_law -- World Justice Project Rule of Law Index (XLSX)
#   fetch.rsf_press_freedom -- RSF World Press Freedom Index (CSV)
#   fetch.ti_cpi -- Transparency International Corruption Perceptions Index (XLSX)
#   fetch.fsi -- Fund for Peace Fragile States Index (XLSX)
#   fetch.gpi -- Global Peace Index (CSV from visionofhumanity.org)
#   fetch.un_egdi -- UN E-Government Development Index (web scrape)


# =============================================================================
#  INTERNATIONAL -- DEVELOPMENT & WELLBEING  (no keys required)
# =============================================================================
# All development modules work without API keys:
#   fetch.undp_hdr -- UNDP Human Development Report indices (CSV)
#   fetch.sdg_index -- Sustainable Development Report index (XLSX)
#   fetch.oecd_sdmx -- OECD Better Life / wellbeing via SDMX (CSV export)
#   fetch.oecd_dac_crs -- OECD DAC/CRS aid flows metadata (SDMX XML)
#   fetch.iati -- IATI Datastore dataset manifest (JSON)
#   fetch.imf_cdis -- IMF CDIS investment survey metadata (SDMX)
#   fetch.nd_gain -- Notre Dame GAIN climate vulnerability index (ZIP/CSV)
#   fetch.world_bank -- World Bank WDI API (JSON, v2)


# =============================================================================
#  GLOBAL DATA HUBS  (no keys required)
# =============================================================================
#   fetch.owid_charts -- Our World in Data chart search & CSV download
#   fetch.owid_catalog -- OWID chart catalog via Datasette API
#   fetch.overture_maps -- Overture geospatial (requires DuckDB; AOI-scoped)


# =============================================================================
#  SURVEYS & MICRODATA  (special requirements noted)
# =============================================================================
#   fetch.atus -- BLS American Time Use Survey file manifest (no key)
#   fetch.brfss -- CDC BRFSS data file manifest (no key)
#   fetch.wvs -- World Values Survey (manual download, license required)
#   fetch.pew -- Pew Research catalog (public); dataset download needs Selenium + account
